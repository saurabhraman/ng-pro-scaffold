{
  "name": "ng-pro-scaffold",
  "version": "1.0.0",
  "description": "An opinionated Angular project scaffolding CLI tool with modern best practices",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "ng-pro-scaffold": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "templates"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm run test -- --watch",
    "test:coverage": "npm run test -- --coverage",
    "lint": "eslint src/ bin/ --ext .js",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\"",
    "prepare": "husky install"
  },
  "keywords": [
    "angular",
    "cli",
    "scaffold",
    "generator",
    "boilerplate",
    "typescript",
    "tailwind",
    "docker"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  }
}